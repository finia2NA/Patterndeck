DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-random-string"
ENCRYPTION_KEY="change-me-32-byte-hex-key-for-aes256"
PORT=3001

# Optional: for social auth
APPLE_CLIENT_ID=""
GOOGLE_CLIENT_ID=""

# Optional: central Anthropic API key for shared usage
# If set, users can use this key instead of providing their own.
ANTHROPIC_API_KEY=""
CENTRAL_KEY_GLOBAL_MONTHLY_LIMIT=100.00

# Optional: additional AI provider keys for admin-configured routing
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
DEEPSEEK_API_KEY=""
MISTRAL_API_KEY=""
KIMI_API_KEY=""
QWEN_API_KEY=""

# Optional: override default base URLs for AI providers
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Optional: transactional email via Resend (used for password reset)
RESEND_API_KEY=""
APP_URL="http://localhost:3001"
EMAIL_FROM="PatternDeck <noreply@example.com>"

# Optional: PostHog analytics, LLM analytics, and error tracking.
# Leave POSTHOG_PROJECT_API_KEY empty or set POSTHOG_ENABLED=0 to disable.
POSTHOG_PROJECT_API_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"
POSTHOG_ENABLED=0
