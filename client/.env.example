# Host and port of the Express API server.
# Defaults to localhost:3001 if not set.
# Set DEV_SERVER_HOST to your machine's IP when testing on a physical device.
DEV_SERVER_HOST=localhost
DEV_SERVER_PORT=3001

# Production API URL baked into native release builds.
EXPO_PUBLIC_API_URL=https://patterndeck.richardhanss.de/api/v1

# Optional: path to the Firebase Android app config file.
# Defaults to ./google-services.json when that file exists.
ANDROID_GOOGLE_SERVICES_FILE=

# Android release signing for local Play builds.
# Keep the keystore itself out of git. Relative paths are resolved from client/android/app.
ANDROID_UPLOAD_STORE_FILE=
ANDROID_UPLOAD_STORE_PASSWORD=
ANDROID_UPLOAD_KEY_ALIAS=
ANDROID_UPLOAD_KEY_PASSWORD=

# Expo project ID used for Expo push notification tokens.
EXPO_PUBLIC_EXPO_PROJECT_ID=156c0c3e-7336-42b4-9805-a98c8fd83832

# Optional: PostHog analytics/error tracking.
# Leave EXPO_PUBLIC_POSTHOG_KEY empty or set EXPO_PUBLIC_ANALYTICS_ENABLED=0 to disable.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_ANALYTICS_ENABLED=0
