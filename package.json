{
  "name": "pattern-deck",
  "private": true,
  "scripts": {
    "backend": "pnpm --filter server dev",
    "client": "pnpm --filter client start",
    "web": "pnpm --filter client web",
    "start": "pnpm --filter client start",
    "fresh": "pnpm --filter client exec expo start --clear",
    "nuke": "lsof -ti :8081 -ti :3001 | xargs kill -9 2>/dev/null; echo 'Killed all processes on ports 8081 and 3001'",
    "dev": "concurrently --raw \"pnpm start\" \"pnpm backend\"",
    "dev:web": "concurrently --raw \"pnpm web\" \"pnpm backend\"",
    "dev:ios": "concurrently --raw \"pnpm ios\" \"pnpm backend\"",
    "dev:android": "concurrently --raw \"pnpm android\" \"pnpm backend\"",
    "ios": "pnpm --filter client ios",
    "ios:phone": "pnpm --filter client ios:phone",
    "android": "pnpm --filter client android",
    "android:phone": "pnpm --filter client android:phone",
    "dev:android:phone": "concurrently --raw \"pnpm android:phone\" \"pnpm backend\"",
    "build:shared": "pnpm --filter @patterndeck/shared build",
    "build:server": "pnpm build:shared && pnpm --filter server build",
    "start:server": "pnpm --filter server start",
    "lint": "pnpm --filter client lint && pnpm --filter client typecheck && pnpm --filter server lint && pnpm --filter server typecheck",
    "lint:client": "pnpm --filter client lint && pnpm --filter client typecheck",
    "lint:server": "pnpm --filter server lint && pnpm --filter server typecheck",
    "db:migrate": "pnpm --filter server db:migrate",
    "db:generate": "pnpm --filter server db:generate",
    "db:push": "pnpm --filter server db:push",
    "pods": "cd client/ios && pod install",
    "prebuild": "pnpm --filter client prebuild",
    "prebuild:clean": "pnpm --filter client prebuild:clean",
    "xcode": "pnpm prebuild && open client/ios/*.xcworkspace",
    "build:web": "pnpm --filter client exec expo export --platform web",
    "ship": "bash deploy/deploy.sh",
    "ship:android": "bash deploy/ship-android.sh",
    "setup:server": "bash deploy/setup-server.sh",
    "wiki": "pnpx codesight wiki"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
